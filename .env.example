# DAP PR Dashboard Configuration
# -----------------------------------
# GitHub API base URL (default: https://api.github.com)
# For GitHub Enterprise, use: https://your-ghe-host/api/v3
GITHUB_API_URL="https://api.github.com"

# GitHub Personal Access Token (required)
GITHUB_TOKEN="your-token-here"

# GitHub organization name
GITHUB_ORG="your-org"

# Repo name filter (regex, case-insensitive). Only repos whose name matches
# are included in auto-discovery.  Leave empty to include ALL repos in the org.
# Examples:  "fusion"  matches any repo with "fusion" in the name
#            "^(fusion|dap)-"  matches repos starting with "fusion-" or "dap-"
GITHUB_REPO_FILTER=""

# SSL verification (set to "false" to skip, e.g. behind corporate proxies)
SSL_VERIFY="true"

# Optional: override the web URL used for PR links in the dashboard
# (auto-derived from GITHUB_API_URL if not set)
# GITHUB_WEB_URL="https://github.com"

# Default lookback window (in days) for the refresh endpoint.
# When /api/refresh is called without a 'since' parameter, only PRs
# created in the last N days are fetched.  Set to 0 to fetch all PRs.
DEFAULT_PR_LOOKBACK_DAYS=7

# Maximum PRs to fetch per repository (safety cap to prevent runaway API usage).
MAX_PRS_PER_REPO=500

# --- Container / deployment settings (optional for local dev) ----------------

# Override the cache file path (default: pr_cache.json next to app.py).
# In Docker this is set to /data/pr_cache.json via docker-compose.yml.
# CACHE_PATH="/data/pr_cache.json"

# When set to "true", logs go to stdout only (no server.log file).
# Useful in containers where logs are collected from stdout.
# LOG_TO_STDOUT="true"

# Redis URL for shared state (optional).
# When set, application state is stored in Redis so multiple workers /
# containers share a single source of truth.  When unset the app falls
# back to plain in-memory dicts (single-process, same as before).
# REDIS_URL="redis://localhost:6379/0"

# Number of gunicorn worker processes (default: 4 with Redis, 1 without).
# WEB_CONCURRENCY=4

# Auto-refresh interval in minutes (0 = disabled).
# When set, the dashboard periodically syncs data from GitHub in the
# background.  Uses the default lookback window (DEFAULT_PR_LOOKBACK_DAYS).
# AUTO_REFRESH_INTERVAL_MINUTES=60

# --- Concurrency settings (optional) ----------------------------------------

# How many repos to fetch/enrich in parallel during a refresh.
# MAX_CONCURRENT_REPOS=4

# How many PRs to enrich in parallel *within* each repo.
# MAX_CONCURRENT_PRS=6

# --- Jenkins integration (optional) ------------------------------------------

# Jenkins credentials for fetching build details (stages, test reports).
# Build URLs are extracted automatically from PR commit-status target_url
# fields, so you only need credentials — not a specific job path.
# JENKINS_USER="your-jenkins-username"
# JENKINS_API_TOKEN="your-jenkins-api-token"

# Comma-separated base URLs of Jenkins servers whose builds may appear in PR
# commit statuses.  Used to match build URLs and route auth.  Leave unset to
# allow any Jenkins URL found in commit statuses.
# JENKINS_URLS="https://jenkins1.example.com,https://jenkins2.example.com"

# --- Reviewer reminders (optional) -------------------------------------------

# Enable automated reviewer reminder comments on PRs waiting for review.
# When enabled, after each sync the system posts @mention comments to
# remind reviewers who haven't responded within the threshold period.
# REMINDER_ENABLED="false"

# Hours a review request must be pending before the first reminder.
# REMINDER_THRESHOLD_HOURS=24

# Minimum hours between repeat reminders for the same reviewer/PR.
# REMINDER_INTERVAL_HOURS=48

# Set to "true" to log what would be posted without actually posting comments.
# REMINDER_DRY_RUN="false"
