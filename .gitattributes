# Normalise line endings: LF in the repo, native on checkout.
* text=auto

# Force LF for files that run inside the Linux container or are
# parsed by tools that choke on CRLF.
*.py        text eol=lf
*.txt       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
.dockerignore text eol=lf
.env.example  text eol=lf
.gitignore  text eol=lf

# Windows helper — keep CRLF so it runs natively.
*.bat       text eol=crlf
